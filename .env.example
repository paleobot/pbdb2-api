# PBDB2 API environment.
# Copy to `.env` and fill in. `.env*` is git-ignored except this example.

# --- Server ---
# HOST=0.0.0.0
# PORT=3000
# NODE_ENV=development

# --- PostgreSQL (reads-only data layer) ---
# Required for DB-backed reads. When unset, the API falls back to stub data and
# `npm test` runs without a database. Mirrors pbdb2-migrations/pg-pool.js.
PG_HOST=localhost
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=pbdb2
# Optional: path to a CA certificate. Its presence enables SSL.
# PG_CA_CERT=/path/to/global-bundle.pem

# Integration tests (`npm run test:integration`) connect with these same
# PG_* vars and need a role permitted to CREATE/DROP DATABASE (they provision
# an ephemeral pbdb2_test_<random> database per run). When PG_* is unset (or
# unreachable), the integration suite SKIPS rather than fails.
#
# The harness loads the backend schema from the sibling pbdb2-migrations repo
# (../../pbdb2-migrations/postgresql/create_new.sql). Override that path if your
# checkout differs:
# CREATE_SQL_PATH=/abs/path/to/create_new.sql
